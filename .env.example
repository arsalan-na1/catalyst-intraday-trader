# Copy this file to .env and fill in real values.
# After filling in: chmod 600 .env

# --- Alpaca ---
# Get from https://alpaca.markets → Paper Trading → View/Generate API Keys.
ALPACA_API_KEY=your_alpaca_paper_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_here
ALPACA_PAPER=true                   # true = paper trading, false = live

# --- Google AI Studio (Gemini 2.5 Flash) ---
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram ---
# Create a bot via @BotFather to get the token.
# Visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# --- NewsAPI.org (optional fallback) ---
# Free tier: 100 requests/day. Register at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# --- Finnhub (optional — insider sentiment, earnings calendar, congressional trades) ---
# Free tier: 60 calls/min. Register at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- Reddit PRAW (optional — social sentiment from WSB/stocks/investing) ---
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=trading-bot/1.0

# --- Strategy thresholds (optional overrides) ---
# PRICE_MOVE_THRESHOLD_PCT=0.08         # 8% move to trigger on main watchlist
# PRICE_TRIGGER_CATALYST_PCT=0.05       # 5% move to trigger on catalyst tickers
# PRICE_MOVE_WINDOW_SECONDS=120
# VOLUME_RATIO_THRESHOLD=5.0            # 5× expected volume to trigger
# VOLUME_TRIGGER_EARNINGS_MULTIPLIER=2.5  # lower bar on confirmed earnings day
# COOLDOWN_MINUTES=5
# EXIT_COOLDOWN_MINUTES=60             # post-close re-entry block (minutes)
# OPENING_BELL_MINUTES=3               # suppress first N minutes of session
# POSITION_SIZE_PCT=0.10
# TAKE_PROFIT_PCT=0.15                  # DEPRECATED — take-profit is now dynamic (see below)
# STOP_LOSS_PCT=0.05                    # fixed hard floor; never dynamic
# MAX_POSITIONS=5
# MIN_GEMINI_CONFIDENCE=7
# MIN_GEMINI_MAGNITUDE=7
# RSI_MAX_ENTRY=72                # bot-side hard ceiling — entries with RSI above
                                   # this are rejected regardless of Gemini verdict.
                                   # Lowered from 82 → 72 to stop buying late-stage
                                   # breakouts that have already exhausted the move.
# REJECT_DOWNTREND=true            # skip entries when daily trend == "downtrend"
                                   # (price < SMA50 AND SMA50 < SMA200)
# FALLING_KNIFE_DRAWDOWN_PCT=0.40  # skip when down >40% from 52w high AND trend
                                   # is not "uptrend" — the AREC pattern
# TREND_GATE_FAIL_CLOSED=true      # when trend or 52w-high distance is missing,
                                   # SKIP on the downtrend + falling-knife gates
                                   # (can't confirm it's safe). RSI gate stays
                                   # fail-open. Set false to restore legacy
                                   # fail-open behavior on the trend gates.

# --- Dynamic take-profit tiers (magnitude-based) ---
# Gemini magnitude score → take-profit target. Magnitude below TP_MAGNITUDE_LOW → trade skipped.
# TP_MAGNITUDE_HIGH=9    # magnitude 9-10 → TP_HIGH_PCT
# TP_HIGH_PCT=0.25
# TP_MAGNITUDE_MID=7     # magnitude 7-8 → TP_MID_PCT
# TP_MID_PCT=0.15
# TP_MAGNITUDE_LOW=5     # magnitude 5-6 → TP_LOW_PCT
# TP_LOW_PCT=0.08

# --- Biotech catalyst fast-track ---
# Raised from 4→6 to reduce gap-down exposure on binary FDA events.
# Position size is hard-capped at BIOTECH_POSITION_SIZE_PCT by
# trader._apply_biotech_cap when the sector returned by
# news.determine_sector() is in BIOTECH_SECTORS — this used to be only a
# Gemini-prompt hint and was being ignored. "unknown" sector is NOT capped
# (fail-safe so a lookup miss doesn't 5%-cap everything).
# BIOTECH_GEMINI_CONFIDENCE=6
# BIOTECH_GEMINI_MAGNITUDE=6
# BIOTECH_POSITION_SIZE_PCT=0.05       # 5% of equity hard cap on biotech names
# BIOTECH_SECTORS is set in code (frozenset({"biotech"})); override by editing
# config.py — not a single-value env var.

# --- Premarket gap scanner (9:00-9:29 ET) ---
# PREMARKET_GAP_PCT=15.0            # min premarket gain % to add ticker to gappers list
# PREMARKET_POLL_SECONDS=120        # how often to poll Alpaca movers endpoint

# --- Gap-open trigger (fires once at 9:30 ET when open gaps vs prev close) ---
# DO NOT lower GAP_OPEN_THRESHOLD below 0.15 — smaller gaps are merger-arb noise.
# GAP_OPEN_THRESHOLD=0.15           # 15% minimum gap to fire (open/prev_close - 1)
# GAP_OPEN_WINDOW_MINUTES=2         # window after 9:30 ET to detect gaps

# --- High-volume / low-price-move confirmation (KALV 1061x style triggers) ---
# Require N consecutive bars with vol_ratio > vol_threshold AND move < min_move
# before firing. Filters noisy volume-only triggers without a price thrust.
# VOLUME_SPIKE_CONFIRM_BARS=2
# VOLUME_SPIKE_CONFIRM_VOL_THRESHOLD=20.0   # vol_ratio above which confirmation is required
# VOLUME_SPIKE_CONFIRM_MIN_MOVE=0.005       # move below which confirmation is required

# --- Risk controls ---
# DAILY_LOSS_LIMIT_PCT=0.02    # daily DD >2% → halve position sizes for rest of session
# DAILY_HALT_PCT=0.03          # daily DD >3% → close all positions + halt trading
# WEEKLY_WARN_PCT=0.05         # weekly DD >5% → halve position sizes for rest of week
# WEEKLY_HALT_PCT=0.07         # weekly DD >7% → close all positions + halt for week
# PEAK_DRAWDOWN_PCT=0.10       # equity >10% below peak → write trading_halted.lock + exit
# MAX_SPREAD_PCT=0.005         # skip trade if bid-ask spread > 0.5%
# CORRELATION_REJECT=0.85      # skip if 60-day return correlation with any open position >85%
# CORRELATION_REDUCE=0.70      # halve position size if correlation >70%
# ENTRY_RETRACE_THRESHOLD=0.6  # skip buy if ≥40% of the spike has already retraced
# MAX_HOLD_MINUTES=90          # fallback for snapshot recovery only; new trades use Gemini's value

# --- Gemini-driven parameter hard limits (floors/ceilings applied in trader.py) ---
# GEMINI_TP_MIN=0.05      # minimum take-profit Gemini can set
# GEMINI_TP_MAX=0.50      # maximum take-profit
# GEMINI_SL_MIN=0.02      # minimum stop-loss
# GEMINI_SL_MAX=0.18      # maximum stop-loss (raised 0.10 → 0.18 so the
                          # ATR floor isn't immediately reclamped down on
                          # high-ATR names)
# GEMINI_SIZE_MIN=0.02    # minimum position size (2% of equity)
# GEMINI_SIZE_MAX=0.12    # maximum position size (12% of equity)
# GEMINI_HOLD_MIN=30      # minimum hold time in minutes
# GEMINI_HOLD_MAX=390     # maximum hold time (full session)
# ATR_SL_MULTIPLIER=1.5   # min SL distance = ATR_SL_MULTIPLIER × daily ATR%
                          # (capped at GEMINI_SL_MAX). Raised 0.5 → 1.5 — a
                          # half-ATR stop gets hit by ordinary noise.
# RISK_PER_TRADE_PCT=0.005  # constant fractional-risk sizing: dollar loss at
                            # stop never exceeds 0.5% of equity. Only ever
                            # reduces the Gemini-set size, never increases.
# MIN_RR_RATIO=2.0        # final take_profit_pct lifted to >= stop_loss_pct
                          # × MIN_RR_RATIO. If stop_loss_pct × MIN_RR_RATIO
                          # would exceed GEMINI_TP_MAX, the trade is SKIPPED
                          # ([RR UNMET]) rather than shipped at degraded RR.

# --- Gemini cost controls ---
# Cost is computed from real response token usage (see GEMINI_TOKEN_PRICING in
# config.py). The flat GEMINI_COST_PER_*_CALL constants are only a conservative
# pre-call budget reservation, reconciled to real cost after each call.
# NOTE: the grounded Google-Search research call was removed; GEMINI_MODEL_RESEARCH
# no longer exists. The thresholds below now only select a telemetry bucket
# (calls_grounded vs calls_ungrounded) — both make the same single verdict call.
# GROUNDING_VOL_THRESHOLD=3.0         # weak-signal bucket if vol_ratio below this
# GROUNDING_PRICE_THRESHOLD=0.03      # AND price move below this
# MAX_GEMINI_CALLS_PER_HOUR=60        # hard cap on total Gemini API calls per hour
# GEMINI_GROUNDING_COST_PER_1K=0.0    # $/1k Search-grounding queries (0 = free quota; real rate 35)
# COST_PERSIST_SECONDS=60             # flush the running cost tally to state/gemini_cost.json this often

# --- Concurrency / rate limiting ---
# GEMINI_CONCURRENCY=2          # max simultaneous in-flight Gemini calls for new entries
# PIPELINE_CONCURRENCY=3        # max simultaneous trigger-pipeline tasks
# VERDICT_CACHE_MINUTES=30      # per-ticker verdict cache TTL (prevents re-scoring same event)
# ADV_FETCH_RETRIES=3           # max retries for ADV/prev-close prefetch on startup
# HEARTBEAT_INTERVAL_MINUTES=30 # how often to log a HEARTBEAT line

# --- Open-position re-evaluation ---
# POSITION_EVAL_INTERVAL_MINUTES=15  # how often to re-score each open position with Gemini
# POSITION_EVAL_MIN_HOLD_MINUTES=10  # skip positions younger than this many minutes
# POSITION_EVAL_SEMAPHORE_LIMIT=2    # max concurrent position re-evaluation Gemini calls
# FORCED_REEVAL_LOSS_PCT=0.015       # force re-eval (bypass news fingerprint) when P&L < -1.5%

# --- Day-trader session limits ---
# EOD_CLOSE_HOUR=15             # close all positions at 3:45 PM ET
# EOD_CLOSE_MINUTE=45
# NO_NEW_POSITIONS_AFTER_HOUR=15   # no new buys after 3:30 PM ET
# NO_NEW_POSITIONS_AFTER_MINUTE=30

# --- Stale trigger guard ---
# Skip queued triggers that are old AND the price has reversed.
# STALE_TRIGGER_MINUTES=5
# STALE_TRIGGER_REVERSAL_PCT=0.03

# --- Micro-cap catalyst screener ---
# MICROCAP_ENABLED=true
# MICROCAP_POLL_SECONDS=180
# MICROCAP_PRICE_MIN=1.00
# MICROCAP_PRICE_MAX=20.00
# MICROCAP_VOL_RATIO_MIN=4.0
# MICROCAP_MARKET_CAP_MAX=500000000
# MICROCAP_DEDUP_HOURS=6
# MICROCAP_MIN_DOLLAR_VOLUME=500000  # price × volume must exceed this (avoids illiquid junk)
# MICROCAP_VOL_THRESHOLD=5.0         # pre-Gemini filter: vol_ratio must exceed this
# MICROCAP_PRICE_THRESHOLD=0.05      # pre-Gemini filter: intraday price change must exceed this

# --- Kronos secondary confirmation ---
# After a Gemini buy verdict passes all gates, Kronos-mini scores a short-horizon
# continuation probability from the last 60 one-minute bars. If the probability
# is below KRONOS_MIN_PROB the buy is downgraded to a skip (no cooldown set).
# Failure modes (model unavailable, fetch error) fall through silently and the
# trade proceeds on the Gemini verdict alone.
# Requires NeoQuasar's Kronos checkout at /home/aso/Kronos to actually run;
# set USE_KRONOS=false to skip the model entirely.
# USE_KRONOS=true
# KRONOS_MIN_PROB=0.45

# --- Congressional-trade copy (OFF by default; see docs/specs/congress-copy.md) ---
# A separate, fully-virtual paper portfolio that copies recently DISCLOSED
# congressional BUYs, for head-to-head benchmarking against the scalper. It
# places NO real Alpaca orders and shares no state with the live bot.
#
# Data source: leave CONGRESS_DATA_API_KEY BLANK to run keyless on the Senate
# Stock Watcher fallback (Senate-only coverage). To turn on FULL House+Senate
# coverage, paste a FREE Financial Modeling Prep key here (no payment; the free
# tier's 250 calls/day dwarfs one daily pull):
#     get a free key at https://site.financialmodelingprep.com/  ->  paste below
# CONGRESS_DATA_API_KEY=
#
# Master switch for the virtual portfolio. With it false (default) no congress
# coroutine starts, no congress network/disk I/O happens, and the bot behaves
# byte-identically to today.
# CONGRESS_COPY_ENABLED=false
# CONGRESS_SIZING_MODE=equal_weight        # equal_weight (default) | range_tier
# CONGRESS_EQUAL_WEIGHT_USD=1000           # virtual $ per disclosed buy
# CONGRESS_VIRTUAL_EQUITY_USD=100000       # virtual account size for the benchmark
# CONGRESS_FMP_LIMIT=250                   # rows per chamber (paid tier only; see below)
# FMP's FREE tier 402s when page/limit are sent to the *-latest endpoints, so the
# default request sends only the apikey. Set true ONLY with a paid FMP key.
# CONGRESS_FMP_PAID_TIER=false
# CONGRESS_FRESHNESS_DAYS=60               # max TRANSACTION age to copy (lag can exceed a year)
# CONGRESS_BUY_ASSET_TYPES=stock           # allowlist of assetType to copy; add ',reit' to opt REITs in
